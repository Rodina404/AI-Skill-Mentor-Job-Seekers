# =============================================================================
# supabase.example.env
# AI Skill Mentor – Supabase environment variables
#
# Copy this file to backend/.env (or merge into your existing .env) and
# replace every placeholder value with the real credential from the dashboard.
#
# Find all values at:
#   Supabase Dashboard → [Your Project] → Project Settings → API
# =============================================================================

# The unique REST API base URL for your Supabase project.
# Example: https://xyzcompany.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# The public anonymous key – safe to use in browser / RLS-enforced calls.
# Labeled "anon public" in the dashboard.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# The secret service-role key – bypasses RLS, SERVER SIDE ONLY.
# NEVER commit this to git or expose it to the browser.
# Labeled "service_role secret" in the dashboard.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here
