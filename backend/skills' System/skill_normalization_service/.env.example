# Skill Normalization Service Configuration

# Service Port
SERVICE_PORT=8003

# Environment (development/production)
ENV=development

# Logging
LOG_LEVEL=INFO

# CORS Configuration
ALLOWED_ORIGIN=http://localhost:3000

# Model Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
SIMILARITY_THRESHOLD=0.7

# Features
ENABLE_CACHING=true
CACHE_TTL_SECONDS=3600
