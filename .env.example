# ==============================================================================
# Global Environment Configuration
# ==============================================================================

# ── M1: Extraction Service & M4: Gap Engine (Mode B) ──────────────────────────
# Required by m1_extraction_service to extract resume fields.
# Also used by gap-engin-service as a fallback (Mode B) for non-indexed roles.
# Get a free API key at: https://console.groq.com
GROQ_API_KEY=

# ── M5: Roadmap Service ───────────────────────────────────────────────────────
# Requires exactly ONE of the following LLM API keys for roadmap generation.
# Prioritized order in code: ANTHROPIC > QWEN > DASHSCOPE > OPENAI
ANTHROPIC_API_KEY=
# QWEN_API_KEY=
# DASHSCOPE_API_KEY=
# OPENAI_API_KEY=

# ── Backend: Supabase Configuration ───────────────────────────────────────────
# REQUIRED for backend startup and auth operations.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Backend: JWT Configuration ────────────────────────────────────────────────
# REQUIRED for backend auth.
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Gap Engine (Mode B Only) ──────────────────────────────────────────────────
# Required ONLY if testing uncommon job titles not in the 89 pre-indexed roles.
# Provides fallback role fetching via Adzuna API.
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
